{
  "name": "@holz/monorepo",
  "private": true,
  "description": "Monorepo for all packages under the @holz organization",
  "repository": "https://github.com/github:PsychoLlama/holz",
  "author": "Jesse Gibson",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "prepare": "pnpm -r run prepack",
    "check": "turbo run test:types test:unit lint fmt-check",
    "test": "pnpm check",
    "test:coverage": "pnpm -r run test:unit -- --coverage --no-watch",
    "lint": "eslint packages/*/src --ext ts,tsx --color --cache --cache-location node_modules/.cache/eslint/",
    "fmt-check": "treefmt --ci",
    "release:candidate": "lerna publish --canary --preid rc --dist-tag rc --force-publish --yes"
  },
  "prettier": {
    "singleQuote": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "lerna": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.26.0"
  }
}
