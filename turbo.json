{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.json"],
  "globalPassThroughEnv": ["FORCE_COLOR", "CLICOLOR_FORCE"],
  "tasks": {
    "prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "test:types": {
      "dependsOn": ["^test:types"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "//#test:types": {
      "inputs": ["eslint.config.ts", "tsconfig.json", "tsconfig.eslint.json"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test:unit": {
      "dependsOn": ["^test:types"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test:coverage": {
      "dependsOn": ["^test:types"],
      "outputs": ["coverage/**"],
      "outputLogs": "errors-only"
    },
    "//#knip:dev": {
      "inputs": [
        "packages/*/src/**",
        "packages/*/package.json",
        "knip.config.ts",
        "*.ts"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "//#knip:production": {
      "dependsOn": [
        "@holz/ansi-terminal-backend#prepack",
        "@holz/console-backend#prepack",
        "@holz/core#prepack",
        "@holz/env-filter#prepack",
        "@holz/json-backend#prepack",
        "@holz/log-collector#prepack",
        "@holz/logger#prepack",
        "@holz/pattern-filter#prepack",
        "@holz/stream-backend#prepack"
      ],
      "inputs": [
        "packages/*/src/**",
        "packages/*/package.json",
        "packages/*/dist/**",
        "knip.config.ts",
        "*.ts"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "//#lint": {
      "inputs": [
        "packages/*/src/**/*.{ts,tsx}",
        "packages/*/tsconfig.json",
        "eslint.config.ts",
        "tsconfig.json",
        ".gitignore"
      ],
      "outputs": ["node_modules/.cache/eslint/**"],
      "outputLogs": "errors-only"
    },
    "//#fmt-check": {
      "inputs": [
        "**/*.{js,mjs,cjs,ts,tsx,json,md,yaml,yml,css,html,nix}",
        "!**/node_modules/**",
        "!**/dist/**",
        "!**/.turbo/**",
        "!**/coverage/**",
        "!.direnv/**",
        "treefmt.toml"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    }
  }
}
