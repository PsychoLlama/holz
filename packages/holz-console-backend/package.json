{
  "name": "@holz/console-backend",
  "version": "0.9.0",
  "description": "A console backend for Holz",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PsychoLlama/holz",
    "directory": "packages/holz-console-backend"
  },
  "exports": {
    ".": {
      "types": "./dist/holz-console-backend.d.ts",
      "require": "./dist/holz-console-backend.cjs",
      "import": "./dist/holz-console-backend.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Jesse Gibson",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "holz-backend",
    "console",
    "browser",
    "debugger"
  ],
  "scripts": {
    "prepack": "vite build",
    "test:unit": "vitest run --color --passWithNoTests",
    "test:coverage": "vitest run --coverage --color --passWithNoTests",
    "test:types": "tsc"
  },
  "peerDependencies": {
    "@holz/core": "^0.8.0 || ^0.9.0"
  },
  "devDependencies": {
    "@holz/core": "workspace:^",
    "@microsoft/api-extractor": "^7.58.8",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
