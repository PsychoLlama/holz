{
  "name": "@holz/logger",
  "version": "0.9.0",
  "description": "A preconfigured, general-purpose logger",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PsychoLlama/holz",
    "directory": "packages/holz-logger"
  },
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser-logger.d.ts",
        "import": "./dist/browser-logger.js",
        "require": "./dist/browser-logger.cjs"
      },
      "default": {
        "types": "./dist/server-logger.d.ts",
        "import": "./dist/server-logger.js",
        "require": "./dist/server-logger.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Jesse Gibson",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "holz",
    "logger",
    "preconfigured",
    "browser",
    "node",
    "deno"
  ],
  "scripts": {
    "prepack": "vite build",
    "test:unit": "vitest run --color --passWithNoTests",
    "test:coverage": "vitest run --coverage --color --passWithNoTests",
    "test:types": "tsc"
  },
  "dependencies": {
    "@holz/ansi-terminal-backend": "workspace:^",
    "@holz/console-backend": "workspace:^",
    "@holz/core": "workspace:^",
    "@holz/env-filter": "workspace:^",
    "@holz/log-collector": "workspace:^",
    "@holz/stream-backend": "workspace:^"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.8",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^7.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
